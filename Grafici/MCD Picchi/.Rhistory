# Librerie
library(plotly)
# -----------------------------
# 1. Lista file
# -----------------------------
files <- sprintf("files/tek%04dCH1.csv", 21:59)
# -----------------------------
# 2. Estrazione massimi
# -----------------------------
massimi <- sapply(files, function(f) {
dati <- read.csv(f, skip = 20)
max(dati$CH1, na.rm = TRUE)
})
massimi <- na.omit(massimi)
cat("Massimi originali:\n")
print(massimi)
# -----------------------------
# 3. Filtro (togli outlier > 0.002 V)
# -----------------------------
soglia_max <- 0.002
massimi_filtrati <- massimi[massimi <= soglia_max]
cat("Massimi filtrati:\n")
print(massimi_filtrati)
# -----------------------------
# 4. Clustering (4 celle)
# -----------------------------
set.seed(1)
k <- kmeans(massimi_filtrati, centers = 4)
# Centri dei cluster (ordinati)
centri <- sort(k$centers[,1])
cat("Centri cluster (V):\n")
print(centri)
# -----------------------------
# 5. Stima tensione cella
# -----------------------------
differenze <- diff(centri)
cat("Differenze tra cluster:\n")
print(differenze)
cella <- median(differenze)
cat("Stima tensione cella (V):", cella, "\n")
# -----------------------------
# 6. Istogramma con cluster
# -----------------------------
nbins <- 50
fig <- plot_ly(
x = massimi_filtrati,
type = "histogram",
nbinsx = nbins
)
# aggiunta linee verticali dei cluster
for (c in centri) {
fig <- fig %>% add_vlines(x = c)
}
# Librerie
library(plotly)
# -----------------------------
# 1. Lista file
# -----------------------------
files <- sprintf("files/tek%04dCH1.csv", 21:59)
# -----------------------------
# 2. Estrazione massimi
# -----------------------------
massimi <- sapply(files, function(f) {
dati <- read.csv(f, skip = 20)
max(dati$CH1, na.rm = TRUE)
})
massimi <- na.omit(massimi)
cat("Massimi originali:\n")
print(massimi)
# -----------------------------
# 3. Filtro (togli outlier > 0.002 V)
# -----------------------------
soglia_max <- 0.002
massimi_filtrati <- massimi[massimi <= soglia_max]
cat("Massimi filtrati:\n")
print(massimi_filtrati)
# -----------------------------
# 4. Clustering (4 celle)
# -----------------------------
set.seed(1)
k <- kmeans(massimi_filtrati, centers = 4)
# Centri dei cluster (ordinati)
centri <- sort(k$centers[,1])
cat("Centri cluster (V):\n")
print(centri)
# -----------------------------
# 5. Stima tensione cella
# -----------------------------
differenze <- diff(centri)
cat("Differenze tra cluster:\n")
print(differenze)
cella <- median(differenze)
cat("Stima tensione cella (V):", cella, "\n")
# -----------------------------
# 6. Istogramma con linee cluster
# -----------------------------
nbins <- 50
fig <- plot_ly(
x = massimi_filtrati,
type = "histogram",
nbinsx = nbins
)
# Creazione linee verticali
shapes_list <- lapply(centri, function(c) {
list(
type = "line",
x0 = c,
x1 = c,
y0 = 0,
y1 = 1,
yref = "paper",  # tutta l'altezza del grafico
line = list(dash = "dash")
)
})
fig <- fig %>% layout(
title = "Istogramma + cluster (SiPM)",
xaxis = list(title = "Tensione (V)"),
yaxis = list(title = "Conteggi"),
shapes = shapes_list
)
fig
library(plotly)
# -----------------------------
# 1. Lista file
# -----------------------------
files <- sprintf("files/tek%04dCH1.csv", 21:59)
# -----------------------------
# 2. Estrazione massimi
# -----------------------------
massimi <- sapply(files, function(f) {
dati <- read.csv(f, skip = 20)
max(dati$CH1, na.rm = TRUE)
})
massimi <- na.omit(massimi)
# -----------------------------
# 3. Filtro (togli outlier > 0.002 V)
# -----------------------------
soglia_max <- 0.002
massimi_filtrati <- massimi[massimi <= soglia_max]
# -----------------------------
# 4. Clustering (4 celle)
# -----------------------------
set.seed(1)
k <- kmeans(massimi_filtrati, centers = 4)
centri <- sort(k$centers[,1])
# -----------------------------
# 5. Stima tensione cella
# -----------------------------
differenze <- diff(centri)
cella <- median(differenze)
# -----------------------------
# 6. Istogramma con linee cluster corretto
# -----------------------------
nbins <- 50
fig <- plot_ly(
x = massimi_filtrati,
type = "histogram",
nbinsx = nbins,
marker = list(color = 'lightblue')
)
# Linee verticali: usare yref = "paper" è ok, ma meglio allargare y1
shapes_list <- lapply(centri, function(c) {
list(
type = "line",
x0 = c, x1 = c,
y0 = 0, y1 = 1,
yref = "paper",
line = list(color = "red", dash = "dash", width = 2)
)
})
fig <- fig %>% layout(
title = "Istogramma + cluster (SiPM)",
xaxis = list(title = "Tensione (V)"),
yaxis = list(title = "Conteggi"),
shapes = shapes_list
)
fig
